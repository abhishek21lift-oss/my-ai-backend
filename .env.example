# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# Async driver (used by the app at runtime)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_backend

# Sync driver (used by Alembic migrations only)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/ai_backend

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── DB Connection Pool ────────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
