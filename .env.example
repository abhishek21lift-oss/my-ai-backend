# ══════════════════════════════════════════════════════════════════════════════
# ViralAI Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# Generate secrets with: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Database (Supabase or local PostgreSQL) ───────────────────────────────────
# Local dev:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_backend
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/ai_backend

# Supabase (transaction pooler — use port 6543 for serverless):
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Redis (Upstash or local) ──────────────────────────────────────────────────
# Local dev:
REDIS_URL=redis://localhost:6379

# Upstash (TLS required in production):
# REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Security ──────────────────────────────────────────────────────────────────
# Protects /api/v1/cron/* HTTP endpoints.
CRON_SECRET=change-me-use-openssl-rand-hex-32

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list. Add your Vercel production URL here.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── DB Connection Pool ────────────────────────────────────────────────────────
# Lower values recommended when using Supabase transaction pooler.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
